# 新媒体运营 AI 系统 - 环境变量配置模板
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# DeepSeek API 配置 (推荐使用 - 性价比高)
# ============================================
# 获取 API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# OpenAI API 配置 (可选)
# ============================================
# 获取 API Key: https://platform.openai.com/
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4

# ============================================
# Azure OpenAI 配置 (可选)
# ============================================
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_here
# AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=your_deployment_name

# ============================================
# 应用配置
# ============================================
# LOG_LEVEL=INFO
# HOST=localhost
# PORT=8080

# ============================================
# 数据库配置 (可选 - 未来功能)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# REDIS_URL=redis://localhost:6379/0

# ============================================
# 平台 API 配置 (可选 - 未来功能)
# ============================================
# 微信公众号
# WECHAT_APP_ID=your_app_id
# WECHAT_APP_SECRET=your_app_secret

# 微博
# WEIBO_APP_KEY=your_app_key
# WEIBO_APP_SECRET=your_app_secret

# 抖音
# DOUYIN_CLIENT_KEY=your_client_key
# DOUYIN_CLIENT_SECRET=your_client_secret